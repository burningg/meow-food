{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mvn spring-boot:run",
      "type": "shell",
      "command": "mvn",
      "args": [
        "spring-boot:run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/food-service/food",
        "env": {
          "JAVA_HOME": "/opt/homebrew/Cellar/openjdk@17/17.0.15/libexec/openjdk.jdk/Contents/Home",
          "PATH": "/opt/homebrew/Cellar/openjdk@17/17.0.15/libexec/openjdk.jdk/Contents/Home/bin:${env:PATH}"
