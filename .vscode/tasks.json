{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mvn: compile food-service/food",
      "type": "shell",
      "command": "mvn",
      "args": [
        "-f",
        "${workspaceFolder}/food-service/food/pom.xml",
        "-DskipTests",
        "compile"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$javac"
      ]
    }
  ]
}
